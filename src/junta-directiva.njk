---
layout: layouts/base.njk
title: "Junta Directiva - ASAOSA"
description: "Conoce a los miembros de la Junta Directiva de ASAOSA que lideran nuestra organización."
---

<main>
  <section class="min-h-[45vh] flex items-center justify-center relative overflow-hidden pt-20">
    <div class="absolute inset-0 bg-gradient-to-br from-[rgba(45,80,22,0.85)] to-[rgba(74,124,47,0.8)] z-[1]"></div>
    <div class="max-w-[1400px] mx-auto px-8 py-16 text-center relative z-[10]">
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4 capitalize text-white drop-shadow-md">Junta Directiva</h1>
      <p class="text-white text-lg md:text-xl font-light drop-shadow-sm">Las personas detrás de la Asociación que hacen esto posible</p>
    </div>
  </section>

  <!-- Board Members Grid -->
  <section class="relative py-20 bg-[#F5F5F0]">
    <div class="max-w-7xl mx-auto px-0 px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mx-12 lg:mx-0">
        {% for miembro in junta %}
        <div 
          data-aos="fade-up"
          data-aos-delay="{{ loop.index0 * 100 }}"
          class="bg-white p-10 border-l-4 border-primary shadow-sm rounded-md flex flex-col justify-between hover:shadow-md transition-shadow">
          <div>
            <div class="text-2xl font-semibold text-primary mb-2">{{ miembro.puesto }}</div>
            <h3 class="text-xl font-bold text-brand-green-dark my-2">{{ miembro.nombre }}</h3>
            <div class="text-sm text-gray-600">Cédula: {{ miembro.cedula }}</div>
            <div class="text-sm text-gray-600">Representación: {{ miembro.representacion }}</div>
          </div>
          <div class="mt-6">
            <span
              class="inline-flex items-center px-3 py-1 rounded-sm text-xs font-semibold bg-primary/10 text-brand-green-dark border border-primary/20">
              Vigencia: {{ miembro.vigencia }}
            </span>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>
</main>