---
layout: layouts/base.njk
title: "Donaciones - ASAOSA"
description: "Apoya nuestra labor de reciclaje y valorización de residuos en la Península de Osa con tu donación."
---


<!-- Hero Section -->
<section class="relative min-h-[45vh] flex items-center justify-center overflow-hidden pt-20">
  <div class="absolute inset-0 bg-gradient-to-br from-[#2D5016]/85 to-[#4A7C2F]/80 z-10"></div>
  <div class="relative z-20 max-w-[1400px] mx-auto px-8 py-16 text-center">
    <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-4 capitalize leading-tight">Apoya Nuestra Misión</h1>
    <p class="text-white text-lg md:text-xl font-light opacity-90 max-w-2xl mx-auto">
      Tu donación ayuda a crear un futuro más sostenible a través del reciclaje y la valorización de residuos.
    </p>
  </div>
</section>


<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12">
  <div class="text-center mb-12">
    <span class="text-primary font-bold tracking-widest uppercase text-xs">Donaciones</span>
    <h2 class="font-display text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">Tu donación nos permite:
    </h2>
    <div class="w-20 h-1 bg-secondary mx-auto rounded-full mb-6"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
    {% for beneficio in donaciones.beneficios %}
    <div
      data-aos="fade-up"
      data-aos-delay="{{ loop.index0 * 100 }}"
      class="flex flex-col justify-start items-center gap-4 bg-white dark:bg-surface-dark rounded-xl p-8 border border-gray-100 dark:border-gray-800 shadow-sm hover:shadow-md transition-shadow group">
      <div
        class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mb-4 group-hover:bg-primary/20 transition-colors">
        <span class="material-symbols-outlined text-[3rem] text-primary">{{ beneficio.icono }}</span>
      </div>
      <h4 class="text-[#2D5016] dark:text-primary font-bold text-xl mb-2">{{ beneficio.titulo }}</h4>
      <p class="text-gray-600 dark:text-gray-400 text-center text-[0.95rem] leading-relaxed">
        {{ beneficio.descripcion }}
      </p>
    </div>
    {% endfor %}
  </div>

  <p class="mt-12 text-[0.95rem] text-gray-500 dark:text-gray-400 text-center max-w-2xl mx-auto italic">
    Aclaración: ASAOSA es una organización sin fines de lucro dedicada a la valorización integral de residuos en
    toda la Península de Osa.
  </p>
</section>

<!-- Formas de Donar Section -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12">
  <div class="text-center mb-12">
    <span class="text-primary font-bold tracking-widest uppercase text-xs">Apoyo economico</span>
    <h2 class="font-display text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">Formas de Donar
    </h2>
    <div class="w-20 h-1 bg-secondary mx-auto rounded-full mb-6"></div>
  </div>
  <div
    class="relative text-white bg-gradient-to-br from-[#4A7C2F] to-[#2D5016] rounded-3xl p-8 md:p-12 mb-20 overflow-hidden shadow-xl"
    aria-labelledby="donate-title">
    <!-- Subtle Glow Overlay -->
    <div class="absolute inset-0 z-0 pointer-events-none opacity-20">
      <div
        class="absolute -top-[20%] -right-[20%] w-[60%] h-[60%] bg-[radial-gradient(closest-side,#fff_0%,transparent_70%)] rounded-full">
      </div>
    </div>

    <div class="relative z-10 max-w-5xl mx-auto">
      <p id="donate-status" class="min-h-[1.5rem] text-center text-yellow-200 text-sm mb-8" role="status"
        aria-live="polite"></p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {% for cuenta in donaciones.cuentas %}
        <article
          data-aos="zoom-in"
          class="bg-white/10 border border-white/20 rounded-2xl backdrop-blur-md shadow-lg p-8 flex flex-col justify-between">
          <header class="flex items-center gap-3 mb-6 border-b border-white/10 pb-4">
            <span class="material-symbols-outlined text-[2rem] text-white">{{ cuenta.icono }}</span>
            <h3 class="text-yellow-200 text-xl font-bold">{{ cuenta.tipo }}</h3>
          </header>

          <div class="space-y-6">
            <div class="flex flex-col gap-1">
              <span class="text-[#A5D6A7] font-bold text-xs uppercase tracking-wider">{{ 'Banco' if 'IBAN' in cuenta.tipo else 'Teléfono' }}</span>
              <span class="font-medium">{{ cuenta.banco }}</span>
            </div>
            <div class="flex flex-col gap-2">
              <span class="text-[#A5D6A7] font-bold text-xs uppercase tracking-wider">{{ 'IBAN' if 'IBAN' in cuenta.tipo else 'Número' }}</span>
              <div class="flex flex-wrap items-center gap-3">
                <code
                  class="code-inline bg-black/20 border border-white/10 px-3 py-1.5 rounded-lg font-mono text-sm tracking-widest text-white">{{ cuenta.valor }}</code>
                <button
                  class="px-4 py-1.5 bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg text-sm font-bold transition-all hover:translate-y-[-1px] copy-btn"
                  data-copy="{{ cuenta.valor }}" aria-label="Copiar datos de cuenta">
                  Copiar
                </button>
              </div>
            </div>
            <div class="flex flex-col gap-1">
              <span class="text-[#A5D6A7] font-bold text-xs uppercase tracking-wider">Beneficiario</span>
              <span class="font-medium">{{ cuenta.beneficiario }}</span>
            </div>
          </div>
        </article>
        {% endfor %}

        <!-- PayPal -->
        <article
          data-aos="zoom-in"
          class="bg-white/10 border border-white/20 rounded-2xl backdrop-blur-md shadow-lg p-8 flex flex-col justify-between">
          <header class="flex items-center gap-3 mb-6 border-b border-white/10 pb-4">
            <span class="material-symbols-outlined text-[2rem] text-white">credit_card</span>
            <h3 class="text-yellow-200 text-xl font-bold">PayPal</h3>
          </header>

          <div class="space-y-6">
            <p class="text-gray-100/90 leading-relaxed">
              {{ donaciones.paypal.descripcion }}
            </p>
            <a href="{{ donaciones.paypal.url }}" target="_blank" title="Donar vía PayPal"
              class="inline-flex items-center justify-center w-full px-6 py-3 bg-[#0070BA] hover:bg-[#005ea6] text-white font-bold rounded-xl shadow-[0_6px_16px_rgba(0,112,186,0.35)] transition-all hover:translate-y-[-1px] hover:shadow-[0_10px_24px_rgba(0,112,186,0.5)]">
              Donar con PayPal
            </a>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<!-- Donación de Materiales Section -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="text-center mb-10">
    <span class="text-primary font-bold tracking-widest uppercase text-xs">Apoyo en especie</span>
    <h3 class="font-display text-3xl font-bold text-gray-900 dark:text-white mb-4">Donación de Materiales y
      Equipos</h3>
    <div class="w-16 h-1 bg-secondary mx-auto rounded-full"></div>
  </div>

  <div
    data-aos="fade-up"
    class="bg-[#E8F5E9] dark:bg-green-900/10 p-8 rounded-2xl border border-green-100 dark:border-green-800/20 max-w-4xl mx-auto shadow-sm">
    <h2 class="text-[#2D5016] dark:text-green-400 font-bold text-lg md:text-xl mb-6 flex items-center gap-2">
      <span class="material-symbols-outlined">emoji_objects</span>
      También aceptamos materiales que nos ayuden en nuestra labor operativa:
    </h2>
    <ul class="grid md:grid-cols-2 gap-4 ml-4">
      {% for material in donaciones.en_especie %}
      <li class="flex items-center gap-3 text-gray-700 dark:text-gray-300">
        <span class="w-2 h-2 rounded-full bg-secondary"></span>
        {{ material }}
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 my-12">
  <!-- Call to Action Section -->
  <div class="flex flex-col items-center p-12 text-center mb-12">
    <h3 class="text-[#2D5016] dark:text-primary font-display text-3xl font-bold mb-4">¿Tienes Preguntas?</h3>
    <p class="text-gray-600 dark:text-gray-400 text-lg mb-10 max-w-xl mx-auto">
      Contáctanos si deseas más información sobre cómo puedes apoyar nuestra misión de sostenibilidad.
    </p>
    <a href="mailto:Asaosa2005@gmail.com" title="Enviar un correo electrónico para consultas"
      class="inline-flex items-center gap-3 px-8 py-4 bg-primary text-white rounded-full font-bold shadow-lg hover:bg-opacity-90 transition-all hover:scale-[1.02] active:scale-[0.98]">
      <span class="material-symbols-outlined">mail</span>
      Contáctanos por correo electrónico
    </a>
  </div>
</section>

{# CREDENCIALES OFICIALES #}
<section class="bg-primary text-white pt-12 pb-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-12">
      <div class="flex-1 space-y-6">
        <h2 class="font-display text-4xl font-bold text-white">Credenciales
          Oficiales</h2>
        <div class="space-y-4">
          {% for credencial in donaciones.credenciales %}
          <div 
            data-aos="fade-right"
            data-aos-delay="{{ loop.index0 * 150 }}"
            class="flex items-center gap-4 bg-white/5 p-4 border-l-2">
            <span class="material-symbols-outlined">{{ credencial.icono }}</span>
            <div class="flex flex-col">
              <span class="font-mono text-sm tracking-tighter">{{ credencial.etiqueta }}</span>
              <span class="font-mono text-sm tracking-tighter">{{ credencial.valor }}</span>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
      <div data-aos="fade-left">
        <img alt="Autenticidad QR" title="QR de Validación Oficial" class="w-40 h-40 bg-white rounded-sm shadow-2xl" src="/assets/images/qr-cga.png" />
        <p class="mt-4 text-xs font-bold text-center uppercase tracking-widest text-white">
          Validación Oficial</p>
      </div>
    </div>
  </div>
</section>




<script>
  (function donateBlock() {
    const status = document.getElementById('donate-status');
    let timer;

    const copyText = async (text) => {
      try {
        await navigator.clipboard.writeText(text);
        status.textContent = '✓ Texto copiado al portapapeles.';

        clearTimeout(timer);
        timer = setTimeout(() => {
          status.textContent = '';
        }, 3000);
      } catch (err) {
        status.textContent = 'Error al copiar. Por favor, selecciona el texto manualmente.';
      }
    };

    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.dataset.copy || '';
        if (text) copyText(text);
      });
    });
  })();
</script>