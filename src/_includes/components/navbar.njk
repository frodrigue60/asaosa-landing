<header class="header" id="header">
  <nav
    class="fixed w-full z-50 top-0 transition-[background-color,box-shadow] duration-300 bg-surface-light/90 dark:bg-background-dark/90 backdrop-blur-md border-b border-gray-100 dark:border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <div class="flex-shrink-0 flex items-center gap-2">
          <a href="/" class="flex items-center gap-2" title="Ir al inicio">
            <img alt="ASAOSA Logo" title="Logotipo de ASAOSA" class="h-10 w-10 rounded-full" src="/assets/images/asaosa-logo-nav.png" />
            <span
              class="font-display font-bold text-4xl text-primary dark:text-primary uppercase tracking-tight">ASAOSA</span>
          </a>
        </div>
        <div class="hidden md:flex space-x-8 items-center">
          {# Inicio #}
          {% if page.url == '/' %}
          <a class="text-primary dark:text-primary hover:text-gray-500 dark:hover:text-gray-500 font-medium transition-colors"
            href="/" title="Ir a la página de inicio">Inicio</a>
          {% else %}
          <a class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-primary font-medium transition-colors"
            href="/" title="Ir a la página de inicio">Inicio</a>
          {% endif %}
          {# Nosotros #}
          {% if page.url == '/sobre-nosotros/' %}
          <a class="text-primary dark:text-primary hover:text-gray-500 dark:hover:text-gray-500 font-medium transition-colors"
            href="/sobre-nosotros/" title="Conocer más sobre nuestra organización">Nosotros</a>
          {% else %}
          <a class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-primary font-medium transition-colors"
            href="/sobre-nosotros/" title="Conocer más sobre nuestra organización">Nosotros</a>
          {% endif %}
          {# Junta Directiva #}
          {% if page.url == '/junta-directiva/' %}
          <a class="text-primary dark:text-primary hover:text-gray-500 dark:hover:text-gray-500 font-medium transition-colors"
            href="/junta-directiva/" title="Ver los miembros de nuestra junta directiva">Junta Directiva</a>
          {% else %}
          <a class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-primary font-medium transition-colors"
            href="/junta-directiva/" title="Ver los miembros de nuestra junta directiva">Junta Directiva</a>
          {% endif %}

          <a class="bg-primary text-white px-6 py-2.5 rounded-full hover:bg-opacity-90 transition-[background-color,box-shadow] shadow-md hover:shadow-lg font-medium"
            href="/donacion" title="Apoya nuestra causa con una donación">Donación</a>
        </div>
        <div class="md:hidden flex items-center">
          <button id="mobileMenuToggle" aria-controls="navMenu" aria-expanded="false" class="text-gray-600 dark:text-gray-300 hover:text-primary focus:outline-none">
            <span class="material-symbols-outlined text-3xl">menu</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="navMenu"
      class="hidden md:hidden bg-white dark:bg-background-dark border-t border-gray-100 dark:border-gray-800 absolute w-full left-0 shadow-lg">
      <div class="px-4 pt-2 pb-6 space-y-1 sm:px-3">
        <a href="/"
          class="block px-3 py-4 text-base font-medium text-gray-600 dark:text-gray-300 hover:text-primary hover:bg-gray-50 dark:hover:bg-gray-800 rounded-md">Inicio</a>
        <a href="/sobre-nosotros/"
          class="block px-3 py-4 text-base font-medium text-gray-600 dark:text-gray-300 hover:text-primary hover:bg-gray-50 dark:hover:bg-gray-800 rounded-md">Nosotros</a>
        <a href="/junta-directiva/"
          class="block px-3 py-4 text-base font-medium text-gray-600 dark:text-gray-300 hover:text-primary hover:bg-gray-50 dark:hover:bg-gray-800 rounded-md">Junta
          Directiva</a>
        <a href="/donacion"
          class="block px-3 py-4 text-base font-medium text-white bg-primary rounded-md text-center mt-4">Donación</a>
      </div>
    </div>
  </nav>
</header>
