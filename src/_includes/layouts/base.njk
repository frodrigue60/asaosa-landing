<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description"
    content="{{ description or 'ONG dedicada a la valorización de residuos mediante reciclaje y compostaje en la Península de Osa.' }}" />
  <meta name="keywords"
    content="reciclaje, compostaje, valorización de residuos, plásticos PET, plásticos HDPE, cartón, papel, vidrio, aluminio, ASAOSA, Península de Osa" />
  <title>{{ title or 'ASAOSA - Valorización de Residuos' }}</title>

  <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&amp;family=Playfair+Display:wght@600;700&amp;display=swap"
    rel="stylesheet" />
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />
  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
    rel="stylesheet" />

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#799F5E",
            secondary: "#FDBA36",
            "background-light": "#F9FAF8",
            "background-dark": "#1A2018",
            "surface-light": "#FFFFFF",
            "surface-dark": "#2C3329",
            "text-light": "#374151",
            "text-dark": "#E5E7EB",
          },
          fontFamily: {
            sans: ['"DM Sans"', 'sans-serif'],
            display: ['"Playfair Display"', 'serif'],
          }
        },
      },
    };
  </script>

  <style>
    .timeline-scroll-container::-webkit-scrollbar {
      height: 4px;
    }

    .timeline-scroll-container::-webkit-scrollbar-thumb {
      background: #799F5E33;
      border-radius: 10px;
    }

    .timeline-scroll-container::-webkit-scrollbar-thumb:hover {
      background: #799F5E;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
    }

    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }

    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    .section-title {
      font-size: 2.5rem;
    }

    .hero-content {
      font-size: 2.5rem;
    }
  </style>

  <link rel="stylesheet" href="/assets/css/styles.css" />
  <link rel="icon" href="/assets/images/favicon.ico" type="image/x-icon">
</head>

<body>
  {% include "components/navbar.njk" %}

  {{ content | safe }}

  {% include "components/footer.njk" %}


  <script src="/assets/js/script.js"></script>
</body>

</html>