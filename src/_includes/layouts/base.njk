<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description"
    content="{{ description or 'ONG dedicada a la valorización de residuos mediante reciclaje y compostaje en la Península de Osa.' }}" />
  {% if site and site.url %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
  {% endif %}
  {# Open Graph / Social #}
  <meta property="og:title" content="{{ title or 'ASAOSA - Valorización de Residuos' }}" />
  <meta property="og:description" content="{{ description or 'ONG dedicada a la valorización de residuos mediante reciclaje y compostaje en la Península de Osa.' }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:image" content="{{ '/assets/images/og-default.svg' | url }}" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="ASAOSA" />

  {# Twitter #}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title or 'ASAOSA - Valorización de Residuos' }}" />
  <meta name="twitter:description" content="{{ description or 'ONG dedicada a la valorización de residuos mediante reciclaje y compostaje en la Península de Osa.' }}" />
  <meta name="twitter:image" content="{{ '/assets/images/og-default.svg' | url }}" />

  <meta name="keywords"
    content="reciclaje, compostaje, valorización de residuos, plásticos PET, plásticos HDPE, cartón, papel, vidrio, aluminio, ASAOSA, Península de Osa" />
  <title>{{ title or 'ASAOSA - Valorización de Residuos' }}</title>

  <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />
  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
    rel="stylesheet" />

  {# AOS - Animate On Scroll #}
  <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#799F5E",
            secondary: "#FDBA36",
            accent: "#F9A825",
            "brand-green": {
              light: "#7CB342",
              medium: "#4A7C2F",
              dark: "#2D5016",
            },
            "background-light": "#F9FAF8",
            "background-dark": "#1A2018",
            "surface-light": "#FFFFFF",
            "surface-dark": "#2C3329",
            "text-light": "#374151",
            "text-dark": "#E5E7EB",
          },
          fontFamily: {
            sans: ['ui-sans-serif', 'system-ui', '-apple-system', 'BlinkMacSystemFont', '"Segoe UI"', 'Roboto', '"Helvetica Neue"', 'Arial', 'sans-serif'],
            display: ['ui-sans-serif', 'system-ui', '-apple-system', 'BlinkMacSystemFont', '"Segoe UI"', 'Roboto', '"Helvetica Neue"', 'Arial', 'sans-serif'],
          }
        },
      },
    };
  </script>

  {# JSON-LD: Organization Schema #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "ASAOSA",
    "url": "{{ site.url }}",
    "logo": "{{ site.url }}/assets/images/asaosa-logo-nav.png",
    "description": "{{ site.description }}",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Puerto Jiménez",
      "addressRegion": "Puntarenas",
      "addressCountry": "CR"
    }
  }
  </script>

  <style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
    }

    #header nav {
      background-color: white;
      transition: all 0.3s ease;
    }

    .scrolled nav {
      background-color: white;
      box-shadow: 0 4px 16px rgba(45, 80, 22, 0.12);
    }
  </style>

  <link rel="icon" href="/assets/images/favicon.ico" type="image/x-icon">
  
</head>

<body>
  {% include "components/navbar.njk" %}

  <main>
    {{ content | safe }}
  </main>

  {% include "components/footer.njk" %}


  <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
  <script src="/assets/js/script.js"></script>
</body>

</html>
